{
  "name": "simple-signal-desktop",
  "version": "1.0.4",
  "description": "Desktop wrapper for Simple Signal CLI & Web Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:uninstaller": "powershell -ExecutionPolicy Bypass -File ./build-uninstaller.ps1",
    "pack": "npm run build:uninstaller && electron-builder --dir",
    "dist": "npm run build:uninstaller && electron-builder"
  },
  "keywords": [
    "ai",
    "cli",
    "telemetry",
    "electron"
  ],
  "author": "falabellamichael",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.simplesignal.desktop",
    "productName": "Simple Signal Desktop",
    "publish": null,
    "files": [
      "main.js",
      "preload.js",
      "preload_extension.js"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "app-backend",
        "filter": [
          "web_server.py",
          "telemetry.py",
          "ai_cli.py",
          "web_search.py",
          "config.json",
          "requirements.txt",
          "static/**/*"
        ]
      }
    ],
    "extraFiles": [
      {
        "from": "tools/SimpleSignalUninstaller.exe",
        "to": "SimpleSignalUninstaller.exe"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Simple Signal Desktop",
      "artifactName": "SimpleSignal.exe"
    },
    "directories": {
      "output": "dist"
    }
  }
}
